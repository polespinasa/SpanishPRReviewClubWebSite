    {
      "id": "1519729602384236816",
      "type": "Default",
      "timestamp": "2026-06-25T17:42:52.419+02:00",
      "timestampEdited": "2026-06-25T17:43:15.153+02:00",
      "callEndedTimestamp": null,
      "isPinned": false,
      "content": "yo aki tengo dudas mas que respuestas, ¿que es mjr comparar feerate o fee? Entiendo que fee y luego se deberia devolver el fee rate que necesitas para superar el fee de X percentil",
      "author": {
        "id": "342759576338300928",
        "name": "siegfried27",
        "discriminator": "0000",
        "nickname": "arejula27",
        "color": "#992D22",
        "isBot": false,
        "roles": [
          {
            "id": "1483542958153138197",
            "name": "PR Proposer",
            "color": "#992D22",
            "position": 1
          }
        ],
        "avatarUrl": "https://cdn.discordapp.com/avatars/342759576338300928/607f31f990f04c85f4b0500aa08cff4d.png?size=512"
      },
      "attachments": [],
